{
  "name": "@apps-in-toss/unity-sdk-generator",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Automatic Unity SDK generator from TypeScript definitions",
  "scripts": {
    "build": "pnpm exec tsc && pnpm run copy-templates",
    "copy-templates": "node -e \"require('fs').cpSync('src/templates','dist/templates',{recursive:true})\"",
    "generate": "pnpm run build && node dist/index.js generate",
    "format": "pnpm run build && node dist/index.js format",
    "validate": "vitest run",
    "dev": "tsx src/index.ts generate",
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:binding": "vitest run tests/unit/binding.test.ts",
    "test:invariants": "vitest run tests/unit/invariants.test.ts",
    "test:serialization": "vitest run tests/unit/serialization.test.ts",
    "test:differential": "vitest run tests/unit/differential.test.ts",
    "test:multi-version": "vitest run tests/unit/multi-version.test.ts"
  },
  "packageManager": "pnpm@11.6.0",
  "dependencies": {
    "@apps-in-toss/framework": "1.6.0",
    "@apps-in-toss/web-analytics": "2.8.0",
    "@apps-in-toss/web-framework": "2.8.0",
    "commander": "15.0.0",
    "handlebars": "4.7.9",
    "picocolors": "1.1.1",
    "ts-morph": "28.0.0"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/node": "^25.0.8",
    "@vitest/ui": "4.1.8",
    "glob": "13.0.6",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "web-framework-1.10.0": "npm:@apps-in-toss/web-framework@1.10.0",
